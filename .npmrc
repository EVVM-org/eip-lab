# Supply-chain protection: refuse to install any package version
# published less than 3 days (4320 minutes) ago.
# Defends against malicious packages that get yanked within hours/days.
#
# Honored by:
#   - pnpm >= 9.6 via `minimum-release-age`
#   - npm  >= 11.5.0 via `min-release-age`
# Both keys are set so this policy applies regardless of which package
# manager touches the project.

minimum-release-age=4320
min-release-age=4320
